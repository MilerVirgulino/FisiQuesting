rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApproved() {
      return signedIn() && userDoc().data.status == "approved";
    }

    function isAdmin() {
      return signedIn() && userDoc().data.role == "admin" && userDoc().data.status == "approved";
    }

    function isGradeOne(value) {
      return value in ["1", "1 ano", "1º ano", "1Âº ano", "1o ano"];
    }

    function isGradeTwo(value) {
      return value in ["2", "2 ano", "2º ano", "2Âº ano", "2o ano"];
    }

    function isGradeThree(value) {
      return value in ["3", "3 ano", "3º ano", "3Âº ano", "3o ano"];
    }

    function sameGrade(left, right) {
      return left == right
        || (isGradeOne(left) && isGradeOne(right))
        || (isGradeTwo(left) && isGradeTwo(right))
        || (isGradeThree(left) && isGradeThree(right));
    }

    function sameClass(left, right) {
      return left == right
        || (left in ["A", "a"] && right in ["A", "a"])
        || (left in ["B", "b"] && right in ["B", "b"])
        || (left in ["C", "c"] && right in ["C", "c"])
        || (left in ["D", "d"] && right in ["D", "d"])
        || (left in ["E", "e"] && right in ["E", "e"]);
    }

    function isMissionForUser() {
      return isApproved()
        && resource.data.status == "open"
        && sameGrade(resource.data.targetGrade, userDoc().data.grade)
        && sameClass(resource.data.targetClass, userDoc().data.className);
    }

    function isOwnProgressId(progressId) {
      return signedIn() && progressId.matches(request.auth.uid + "_\\d{4}-\\d{2}-\\d{2}");
    }

    function onlyStudentStatsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "totalXp",
        "streak",
        "bestStreak",
        "solvedCount",
        "correctCount",
        "coins",
        "petCare",
        "lastWallMessageAt",
        "showcaseSlots",
        "ownedAvatarItems",
        "completedMissionIds",
        "avatar",
        "updatedAt"
      ]);
    }

    function showcaseSlotCount() {
      return userDoc().data.showcaseSlots is int && userDoc().data.showcaseSlots > 0 ? userDoc().data.showcaseSlots : 1;
    }

    function validRequestedClassTag() {
      return !request.resource.data.keys().hasAny(["requestedClassTag"])
        || (
          request.resource.data.requestedClassTag is string
          && request.resource.data.requestedClassTag.size() <= 80
        );
    }

    match /users/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.role == "student"
        && request.resource.data.status == "pending"
        && validRequestedClassTag();
      allow read: if isSelf(userId) || isAdmin() || isApproved();
      allow update: if isAdmin()
        || (
          isSelf(userId)
          && isApproved()
          && onlyStudentStatsChanged()
        );
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /dailyQuests/{questId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /classrooms/{classroomId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /weeklyMissions/{missionId} {
      allow read: if isAdmin() || isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /customAccessoryRequests/{requestId} {
      allow create: if isAdmin()
        || (
          isApproved()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.status == "pending"
          && request.resource.data.category in ["accessories", "emojis"]
        );
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (isApproved() && resource.data.status == "listed");
      allow update, delete: if isAdmin();
    }

    match /avatarItems/{itemId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /avatarInteractions/{interactionId} {
      allow create: if isApproved()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.emojiId is string
        && request.resource.data.status == "unread";
      allow read: if isAdmin()
        || (
          signedIn()
          && (
            resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid
          )
        );
      allow update: if isApproved()
        && resource.data.toUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "readAt", "updatedAt"]);
      allow delete: if isAdmin();
    }

    match /showcaseLooks/{lookId} {
      allow read: if isAdmin()
        || (
          isApproved()
          && resource.data.status == "published"
          && resource.data.hidden == false
        )
        || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if isApproved()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.slotIndex is number
        && request.resource.data.slotIndex >= 0
        && request.resource.data.slotIndex < 8
        && request.resource.data.status in ["draft", "published"]
        && request.resource.data.hidden == false
        && request.resource.data.fotonizationCount == 0;
      allow update: if isAdmin()
        || (
          isApproved()
          && resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.slotIndex == resource.data.slotIndex
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "ownerNickname",
            "ownerRole",
            "ownerGrade",
            "ownerClassName",
            "name",
            "status",
            "hidden",
            "equippedItems",
            "itemCredits",
            "updatedAt"
          ])
          && request.resource.data.status in ["draft", "published"]
          && request.resource.data.hidden == false
        )
        || (
          isApproved()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["fotonizationCount", "updatedAt"])
          && resource.data.status == "published"
          && resource.data.hidden == false
          && request.resource.data.fotonizationCount >= 0
        );
      allow delete: if isAdmin() || (signedIn() && resource.data.ownerId == request.auth.uid);

      match /fotonizations/{userId} {
        allow read: if isAdmin() || isApproved();
        allow create: if isApproved()
          && request.auth.uid == userId
          && get(/databases/$(database)/documents/showcaseLooks/$(lookId)).data.ownerId != request.auth.uid
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isApproved() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    match /showcaseNotifications/{notificationId} {
      allow read: if isAdmin() || (signedIn() && resource.data.toUserId == request.auth.uid);
      allow create: if isApproved()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.type == "fotonization";
      allow update: if isAdmin()
        || (
          isApproved()
          && resource.data.toUserId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "readAt", "updatedAt"])
        );
      allow delete: if isAdmin();
    }

    match /wallMessages/{messageId} {
      allow read: if isAdmin()
        || (isApproved() && resource.data.status == "visible")
        || (signedIn() && resource.data.authorId == request.auth.uid);
      allow create: if isApproved()
        && request.resource.data.keys().hasOnly([
          "authorId",
          "authorName",
          "authorRole",
          "authorGrade",
          "authorClassName",
          "authorAvatar",
          "text",
          "status",
          "highlighted",
          "cost",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 240
        && request.resource.data.status == "visible"
        && request.resource.data.cost is number
        && request.resource.data.highlighted == isAdmin();
      allow update, delete: if isAdmin();
    }

    match /missionAttempts/{attemptId} {
      allow get: if isAdmin()
        || (signedIn() && attemptId.matches(request.auth.uid + "_.*"))
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isApproved()
        && attemptId.matches(request.auth.uid + "_.*")
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /appConfig/{configId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /userProgress/{progressId} {
      allow read: if isAdmin()
        || isOwnProgressId(progressId)
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isApproved()
        && isOwnProgressId(progressId)
        && request.resource.data.userId == request.auth.uid;
      allow update: if isApproved()
        && isOwnProgressId(progressId)
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();

      match /answers/{answerId} {
        allow read: if isAdmin() || isOwnProgressId(progressId);
        allow create: if isApproved()
          && isOwnProgressId(progressId)
          && (
            request.resource.data.questionId == answerId
            || answerId.matches(request.resource.data.missionId + "_" + request.resource.data.questionId)
          );
        allow update, delete: if false;
      }
    }
  }
}
