rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isApproved() {
      return signedIn() && userDoc().data.status == "approved";
    }

    function isAdmin() {
      return signedIn() && userDoc().data.role == "admin" && userDoc().data.status == "approved";
    }

    function isGradeOne(value) {
      return value in ["1", "1 ano", "1º ano", "1Âº ano", "1o ano"];
    }

    function isGradeTwo(value) {
      return value in ["2", "2 ano", "2º ano", "2Âº ano", "2o ano"];
    }

    function isGradeThree(value) {
      return value in ["3", "3 ano", "3º ano", "3Âº ano", "3o ano"];
    }

    function sameGrade(left, right) {
      return left == right
        || (isGradeOne(left) && isGradeOne(right))
        || (isGradeTwo(left) && isGradeTwo(right))
        || (isGradeThree(left) && isGradeThree(right));
    }

    function sameClass(left, right) {
      return left == right
        || (left in ["A", "a"] && right in ["A", "a"])
        || (left in ["B", "b"] && right in ["B", "b"])
        || (left in ["C", "c"] && right in ["C", "c"])
        || (left in ["D", "d"] && right in ["D", "d"])
        || (left in ["E", "e"] && right in ["E", "e"]);
    }

    function isMissionForUser() {
      return isApproved()
        && resource.data.status == "open"
        && sameGrade(resource.data.targetGrade, userDoc().data.grade)
        && sameClass(resource.data.targetClass, userDoc().data.className);
    }

    function isOwnProgressId(progressId) {
      return signedIn() && progressId.matches(request.auth.uid + "_\\d{4}-\\d{2}-\\d{2}");
    }

    function onlyStudentStatsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "totalXp",
        "streak",
        "bestStreak",
        "solvedCount",
        "correctCount",
        "coins",
        "petCare",
        "ownedAvatarItems",
        "completedMissionIds",
        "avatar",
        "updatedAt"
      ]);
    }

    match /users/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.role == "student"
        && request.resource.data.status == "pending";
      allow read: if isSelf(userId) || isAdmin();
      allow update: if isAdmin()
        || (
          isSelf(userId)
          && isApproved()
          && onlyStudentStatsChanged()
        );
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /dailyQuests/{questId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /weeklyMissions/{missionId} {
      allow read: if isAdmin() || isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /customAccessoryRequests/{requestId} {
      allow create: if isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.category == "accessories";
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /missionAttempts/{attemptId} {
      allow get: if isAdmin()
        || (signedIn() && attemptId.matches(request.auth.uid + "_.*"))
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isApproved()
        && attemptId.matches(request.auth.uid + "_.*")
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /appConfig/{configId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /userProgress/{progressId} {
      allow read: if isAdmin()
        || isOwnProgressId(progressId)
        || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isApproved()
        && isOwnProgressId(progressId)
        && request.resource.data.userId == request.auth.uid;
      allow update: if isApproved()
        && isOwnProgressId(progressId)
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();

      match /answers/{answerId} {
        allow read: if isAdmin() || isOwnProgressId(progressId);
        allow create: if isApproved()
          && isOwnProgressId(progressId)
          && (
            request.resource.data.questionId == answerId
            || answerId.matches(request.resource.data.missionId + "_" + request.resource.data.questionId)
          );
        allow update, delete: if false;
      }
    }
  }
}
